---
source: tests/snapshots_test.rs
expression: "format_show_config(&config, Path::new(\"/tmp/dispatch-agent-test.toml\"))"
---
Config: /tmp/dispatch-agent-test.toml (user)
version: 1

Tier: production
  Agent: main-agent
    cli: claude
    model: sonnet-4
    args: ["--timeout", "30"]
    env:
      file: API_TOKEN <- /etc/secrets/token
      env: API_KEY <- CLAUDE_API_KEY
      source: /opt/env/production.env
